# ============================================
# DATABASE (host/port/name — без паролей, они в docker-compose)
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=taxi_agent
DB_POOL_MIN=5
DB_POOL_MAX=20

# ============================================
# OPENROUTER
# ============================================
OPENROUTER_API_KEY=sk-or-v1-your_key

# Таймаут одного запроса к модели (сек)
OPENROUTER_TIMEOUT=30

# Период обновления кэша списка моделей (сек)
OPENROUTER_MODELS_CACHE_TTL=3600

# Максимум моделей для перебора
OPENROUTER_MAX_MODELS=10

# ============================================
# 2GIS
# ============================================
DGIS_API_KEY=your_api_key

# Yandex Geocoder
YANDEX_GEOCODER_API_KEY=

# Yandex SpeechKit (через AI Studio API Key)
YANDEX_SPEECHKIT_API_KEY=your_speechkit_key
YANDEX_SPEECHKIT_FOLDER_ID=your_yandex_folder
