# ============================================
# POSTGRES (для docker-compose / init.sql)
# Эти credentials используются ТОЛЬКО при:
# - первом запуске БД
# - создании схем, ролей, функций
# ============================================
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_db

# ============================================
# PORTS (опционально — для удобства переопределения)
# ============================================
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000